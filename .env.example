# ═══════════════════════════════════════════════════════════════
# Manowzab Command Center — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่า API Keys
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Firebase Config ──────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.region.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your_project_id

# ─── YouTube Data API Keys (คั่นด้วย comma) ──────────────────
# ใช้สำหรับดึงแชทสดจาก YouTube (รองรับหลาย keys แบบ round-robin)
VITE_YOUTUBE_API_KEYS=key1,key2,key3

# ─── Google Cloud TTS API Keys (คั่นด้วย comma) ──────────────
# ใช้สำหรับ Text-to-Speech อ่านข้อความแชท
VITE_GOOGLE_API_KEYS=key1,key2

# ─── Test Mode (Optional) ────────────────────────────────────
# ถ้าตั้งค่านี้ ระบบจะ Auto-Login ให้ตอนเปิดแอป
# VITE_TEST_EMAIL=admin@example.com
# VITE_TEST_PASSWORD=your_password
